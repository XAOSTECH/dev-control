# Dev-Control GitHub App — environment
# Copy to .env and fill in. Never commit the real .env.

# GitHub App identifiers (from the App settings page)
APP_ID=

# Private key: provide ONE of the following.
#  - PRIVATE_KEY: the full PEM, with literal \n for newlines, OR
#  - PRIVATE_KEY_BASE64: base64 of the PEM file (recommended for env/secrets)
PRIVATE_KEY=
PRIVATE_KEY_BASE64=

# Webhook secret configured on the App
WEBHOOK_SECRET=

# HTTP port the webhook server listens on
PORT=3000

# Bot identity used for git operations in the worker clone
APP_BOT_NAME=dev-control[bot]
APP_BOT_EMAIL=dev-control[bot]@users.noreply.github.com

# Slash-command prefix
COMMAND_PREFIX=/dc

# Optional: override the path to fix-history.sh (defaults to ../scripts/fix-history.sh)
# DC_FIX_HISTORY=/opt/dev-control/scripts/fix-history.sh
